# Zonal Tech backend configuration.
#
# On Zonal Cloud (fullstack app) you DON'T set DATABASE_URL or PORT — the
# platform injects them at deploy time (Postgres on the `postgres` host of
# zonal_net, and the container's HTTP port). The rest below are optional.

# --- Local dev only ---------------------------------------------------------
# Where the API listens. Zonal Cloud overrides this with $PORT.
PORT=8000
# Postgres connection. Zonal Cloud injects this; locally point at your own.
DATABASE_URL=postgresql://zonal:changeme@localhost:5432/zonal
# Set PGSSL=1 if your Postgres requires TLS (most managed clouds; not Zonal's
# in-network Postgres).
# PGSSL=1

# --- Auth -------------------------------------------------------------------
# REQUIRED in production: a long random string. Tokens are invalidated if it changes.
JWT_SECRET=change-me-to-a-long-random-string
# JWT_TTL=30d

# --- First-boot admin -------------------------------------------------------
# A single admin user is seeded on first boot if none exists.
ADMIN_EMAIL=admin@zonaltech.co.ke
ADMIN_PASSWORD=change-me-on-first-login

# --- Licensing --------------------------------------------------------------
# Ed25519 signing seed (base64, 32 bytes). Defaults to the SAME demo seed the
# browser License Generator ships with, so things work out of the box. For real
# sales, generate a fresh seed and paste its PUBLIC key into each product's
# LICENSE_PUBLIC_KEY. The admin dashboard shows the active public key.
# LICENSE_SEED_B64=

# --- Public URL (password-reset links, Stripe return) -----------------------
# Defaults to the request's host. Set explicitly behind a proxy if needed.
# PUBLIC_URL=https://app.zonaltech.co.ke

# --- Email (password reset) -------------------------------------------------
# With no SMTP_HOST the reset link is returned in the API response (dev mode).
# Wire a real provider for production and the link is emailed instead.
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=
# SMTP_FROM=no-reply@zonaltech.co.ke
